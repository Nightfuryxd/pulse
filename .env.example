POSTGRES_PASSWORD=pulse_secret
OPENAI_API_KEY=sk-...
OLLAMA_URL=                    # air-gapped: http://ollama:11434
OLLAMA_MODEL=llama3.1          # model name for Ollama

# Collaboration integrations
SLACK_BOT_TOKEN=xoxb-...
SLACK_DEFAULT_CHANNEL=#incidents
TEAMS_WEBHOOK_URL=
PAGERDUTY_API_KEY=

# ── Local agent ──────────────────────────────────────────────────────────────
NODE_ID=prod-node-01
COLLECT_INTERVAL=10
LOG_PATHS=/var/log/syslog,/var/log/auth.log,/var/log/nginx/error.log
TECH_STACK=django,postgres,nginx,redis

# ── SNMP (routers, switches, firewalls, printers, UPS) ───────────────────────
SNMP_TARGETS=192.168.1.1,192.168.1.254
SNMP_COMMUNITY=public

# ── SSH agentless (remote Linux/Unix without installed agent) ─────────────────
SSH_TARGETS=ops@10.0.1.5,ops@10.0.1.6
SSH_USER=ops

# ── Network auto-discovery ────────────────────────────────────────────────────
ENABLE_DISCOVERY=false
NETWORK_RANGE=192.168.1.0/24

# ── Kubernetes ────────────────────────────────────────────────────────────────
ENABLE_K8S=false
# KUBE_PROXY_URL=http://localhost:8001   # if running outside cluster
# KUBERNETES_SERVICE_HOST is auto-set inside a pod

# ── AWS ───────────────────────────────────────────────────────────────────────
ENABLE_AWS=false
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# Or use IAM role (recommended)

# ── Azure ─────────────────────────────────────────────────────────────────────
ENABLE_AZURE=false
# AZURE_SUBSCRIPTION_ID=...
# AZURE_TENANT_ID=...
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...

# ── GCP ───────────────────────────────────────────────────────────────────────
ENABLE_GCP=false
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT_ID=...

# ── Auto-remediation ──────────────────────────────────────────────────────────
REMEDIATION_SSH_USER=root
REMEDIATION_WEBHOOK_URL=

# ── SDK thresholds ────────────────────────────────────────────────────────────
SLOW_SPAN_MS=2000
