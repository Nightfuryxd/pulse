POSTGRES_PASSWORD=pulse_secret
OPENAI_API_KEY=sk-...
OLLAMA_URL=                    # set for air-gapped: http://ollama:11434

# Collaboration integrations (optional)
SLACK_BOT_TOKEN=xoxb-...
SLACK_DEFAULT_CHANNEL=#incidents
TEAMS_WEBHOOK_URL=             # Microsoft Teams incoming webhook
PAGERDUTY_API_KEY=             # PagerDuty routing key

# ── Local agent ──────────────────────────────────────────────────────────────
NODE_ID=prod-node-01
COLLECT_INTERVAL=10            # seconds between metric collection
LOG_PATHS=/var/log/syslog,/var/log/auth.log,/var/log/nginx/error.log
TECH_STACK=django,postgres,nginx,redis

# ── SNMP polling (routers, switches, firewalls, printers, UPS) ────────────────
SNMP_TARGETS=192.168.1.1,192.168.1.254   # comma-separated IPs
SNMP_COMMUNITY=public                    # SNMPv2c community string

# ── SSH agentless collection (Linux/Unix hosts without installed agent) ────────
SSH_TARGETS=ops@10.0.1.5,ops@10.0.1.6   # user@host, uses passwordless key auth
SSH_USER=ops                             # used by auto-discovery

# ── Auto network discovery (ping sweep + SNMP/SSH probe) ─────────────────────
ENABLE_DISCOVERY=false
NETWORK_RANGE=192.168.1.0/24
